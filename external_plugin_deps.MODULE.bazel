maven.artifact(name = "external_deps", group = "com.fasterxml.jackson.dataformat", artifact = "jackson-dataformat-yaml", version = "2.18.3")
maven.artifact(name = "external_deps", group = "org.yaml", artifact = "snakeyaml", version = "2.3")

# Test deps (owners-common tests)
maven.artifact(name = "external_deps", group = "org.easymock", artifact = "easymock", version = "5.4.0", testonly = True)
