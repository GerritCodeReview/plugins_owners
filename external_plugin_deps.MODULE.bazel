# External Maven dependencies for the owners/owners-common plugin.
# Contributed to the shared external_deps maven install.
# After any change here, regenerate the Gerrit lock file:
#   REPIN=1 bazel run @external_deps//:pin

maven = use_extension("@rules_jvm_external//:extensions.bzl", "maven")

# Runtime deps (owners-common)
maven.artifact(name = "external_deps", group = "com.fasterxml.jackson.core", artifact = "jackson-annotations", version = "2.18.3")
maven.artifact(name = "external_deps", group = "com.fasterxml.jackson.core", artifact = "jackson-core", version = "2.18.3")
